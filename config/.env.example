# ── 基础配置 ─────────────────────────────────────────────────────────────────

# 运行模式: observe | shadow | testnet | live
MODE=observe

# 交易对
SYMBOL=BTCUSDT

# 日志级别: DEBUG | INFO | WARNING
LOG_LEVEL=INFO

# 数据库路径
DB_PATH=/opt/lmr-hunter/data/lmr.db

# Binance API（observe/shadow 模式不需要填写）
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── 特征计算 ──────────────────────────────────────────────────────────────────

# 强平滚动窗口（秒）
LIQ_WINDOW_SEC=5

# Episode 信号方向过滤（默认只看 BTCUSDT SELL 方向强平）
LIQ_SIGNAL_SYMBOL=BTCUSDT
LIQ_SIGNAL_SIDE=SELL

# ── Episode 模型 ──────────────────────────────────────────────────────────────

# 相邻强平间隔超过此值则关闭 episode（秒）
EPISODE_GAP_SEC=30

# episode 总名义价值低于此值则丢弃（噪声过滤，USDT）
EPISODE_NOISE_THRESHOLD_USDT=50000

# 单 episode 最长持续时间（秒），超过则强制关闭
EPISODE_MAX_DURATION_SEC=300

# ── Outcome 回填 ──────────────────────────────────────────────────────────────

# outcome 处理器检查间隔（秒）
OUTCOME_CHECK_SEC=60

# ── 成交队列与吞吐 ────────────────────────────────────────────────────────────

# 单次 flush 的最大 batch 大小（条）
TRADE_BATCH_SIZE=2000

# flush 周期（秒）
TRADE_FLUSH_INTERVAL_SEC=1

# 队列最大长度；超出时最旧样本被丢弃并触发 DEGRADED
TRADE_QUEUE_MAXLEN=50000

# 单轮最多执行多少次 flush（防止事件循环被长时间占用）
TRADE_FLUSH_MAX_BATCHES_PER_TICK=20

# ── 告警 ──────────────────────────────────────────────────────────────────────

# P95 延迟告警阈值（ms）
LATENCY_P95_ALERT_MS=400

# Telegram 告警（可选，留空则不发送）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
